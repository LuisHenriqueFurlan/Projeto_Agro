// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum listingType {
  venda
  aluguel
}

enum Condition {
  ativo
  vendido
  alugado
  pausado
}

model user { 
  id            String   @db.Uuid @default(dbgenerated("gen_random_uuid()")) @unique
  name          String   @db.VarChar(80)
  email         String   @db.VarChar(255) @unique
  password_hash String   @db.VarChar(255)
  cpf           String   @db.VarChar(14) @unique
  cep           String   @db.VarChar(9)
  phone         String   @db.VarChar(16)
  avatar_url    String?  @db.Text
  rating        Decimal? @db.Decimal(3, 2)
  verified      Boolean  @db.Boolean 
  created_at    DateTime @db.Timestamptz() @default(now())
  listing       listing[]
}

model listing {
  id            String        @db.Uuid @default(dbgenerated("gen_random_uuid()")) @unique
  user_id       String        @db.Uuid()
  user          user          @relation(fields: [user_id], references: [id], onDelete: Cascade) 
  title         String        @db.VarChar(100)
  category      String        @db.VarChar(30)
  type          listingType
  price         Decimal       @db.Decimal(12, 2)
  year          Int           @db.SmallInt
  brand         String        @db.VarChar(50)
  model         String        @db.VarChar(50)
  hours         Int?          @db.Integer
  condition     Condition
  description   String?       @db.Text
  location      String        @db.VarChar(60)
  state         String        @db.VarChar(2)
  featured      Boolean       @db.Boolean
  views         Int           @db.Integer
  created_at    DateTime      @db.Timestamptz() @default(now())
  updated_at    DateTime      @db.Timestamptz() @default(now())
}
